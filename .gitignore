# Build directory: intermediate C++ build artifacts
# build/tyche/ contains CMake cache, object files, etc.
# build/ is already ignored above (line 11)

# Test build directory
build_test/

# C++ module-specific build directories (out-of-source builds per module)
src/**/build_default/
src/**/build_standalone/

# Visual Studio / MSVC generated files
*.vcxproj
*.vcxproj.filters
*.sln
*.slnx
*.dir/
src/**/x64/

# Rust build artifacts (redirected to build/rust via .cargo/config.toml)
# Only keep final binaries, ignore intermediate build files
target/
*.rlib

# Rust module-specific target directories (when built standalone)
src/**/target/

# Cargo.lock for library/workspace crates (tracked for binaries, ignored for libs)
# Keep the root Cargo.lock for the workspace, but ignore in module subdirs
src/**/Cargo.lock

